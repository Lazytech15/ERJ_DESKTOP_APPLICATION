{
  "name": "erj-smart-solutions-attendance",
  "version": "2.6.1",
  "description": "ERJ Smart Solution Attendance — React (Vite) frontend + Electron backend",
  "main": "electron/main.js",
  "type": "commonjs",
  "scripts": {
    "dev:frontend": "npm --prefix frontend run dev",
    "dev:electron": "NODE_ENV=development electron .",
    "dev": "concurrently -k \"npm:dev:frontend\" \"wait-on tcp:5173 && npm:dev:electron\"",
    "build:frontend": "npm --prefix frontend run build",
    "start": "npm run build:frontend && electron .",
    "build": "npm run build:frontend && electron-builder",
    "dist": "npm run build:frontend && electron-builder --publish=never",
    "release": "npm run build:frontend && electron-builder --publish=always",
    "postinstall": "npm --prefix frontend install && electron-builder install-app-deps",
    "rebuild": "npx electron-rebuild"
  },
  "keywords": ["electron", "react", "vite", "attendance", "barcode", "employee"],
  "author": "Dev. Emmanuel S. Ablao",
  "license": "MIT",
  "devDependencies": {
    "concurrently": "^9.1.0",
    "electron": "^38.1.2",
    "electron-builder": "^24.13.3",
    "wait-on": "^8.0.1"
  },
  "dependencies": {
    "axios": "^1.11.0",
    "crypto-js": "^4.2.0",
    "electron-log": "^5.4.3",
    "electron-updater": "^6.6.2",
    "express": "^5.1.0",
    "ws": "^8.14.2",
    "xlsx": "^0.18.5",
    "zod": "^3.25.67"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/Lazytech15/JJC_ATTENDANCE_MATERIAL_UI.git"
  },
  "publish": {
    "provider": "github",
    "releaseType": "release"
  },
  "build": {
    "appId": "com.erj.attendance-system",
    "productName": "ERJ Smart Solution Attendance",
    "directories": { "output": "dist-electron" },
    "files": ["electron/**/*", "assets/**/*", "package.json"],
    "asar": true,
    "win": {
      "target": [{ "target": "nsis", "arch": ["x64"] }],
      "icon": "assets/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": true,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "artifactName": "${productName}-${version}-Setup.${ext}"
    },
    "mac": { "target": "dmg", "icon": "assets/icon.icns" },
    "linux": { "target": "AppImage", "icon": "assets/icon.png" },
    "compression": "normal"
  }
}
